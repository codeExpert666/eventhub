<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eventhub.modules.auth.mapper.RoleMapper">

    <!--
        roles 表到 RoleEntity 普通类的显式属性映射。
        这里保留逐列映射，目的和 UserMapper 一致：让实体字段与数据库字段的一一对应关系可审查。
    -->
    <resultMap id="RoleEntityResultMap" type="com.eventhub.modules.auth.entity.RoleEntity">
        <id property="id" column="id" javaType="java.lang.Long"/>
        <result property="code" column="code" javaType="java.lang.String"/>
        <result property="name" column="name" javaType="java.lang.String"/>
        <result property="description" column="description" javaType="java.lang.String"/>
        <result property="createdAt" column="created_at" javaType="java.time.LocalDateTime"/>
    </resultMap>

    <resultMap id="UserRoleCodeResultMap" type="com.eventhub.modules.auth.mapper.result.UserRoleCodeResult">
        <result property="userId" column="user_id" javaType="java.lang.Long"/>
        <result property="roleCode" column="role_code" javaType="java.lang.String"/>
    </resultMap>

    <sql id="RoleColumns">
        id, code, name, description, created_at
    </sql>

    <select id="findByCode" resultMap="RoleEntityResultMap">
        SELECT
        <include refid="RoleColumns"/>
        FROM roles
        WHERE code = #{code}
    </select>

    <select id="findRoleCodesByUserId" resultType="java.lang.String">
        SELECT r.code
        FROM roles r
        JOIN user_roles ur ON ur.role_id = r.id
        WHERE ur.user_id = #{userId}
        ORDER BY r.code ASC
    </select>

    <select id="findRoleCodesByUserIds" resultMap="UserRoleCodeResultMap">
        SELECT ur.user_id,
               r.code AS role_code
        FROM user_roles ur
        JOIN roles r ON r.id = ur.role_id
        WHERE ur.user_id IN
        <foreach collection="userIds" item="userId" open="(" separator="," close=")">
            #{userId}
        </foreach>
        ORDER BY ur.user_id ASC, r.code ASC
    </select>

    <insert id="addRoleToUser">
        INSERT INTO user_roles (user_id, role_id)
        VALUES (#{userId}, #{roleId})
    </insert>
</mapper>
