<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eventhub.modules.auth.mapper.UserMapper">

    <!--
        users 表到 UserEntity 普通类的显式属性映射。
        虽然 application.yml 已开启下划线转驼峰，但这里仍使用 resultMap：
        1. 让学习阶段可以清楚看到每个数据库字段如何进入 Java 持久化对象；
        2. 保证 UserEntity 字段与 users 表字段逐列对应，避免读取字段遗漏；
        3. 后续字段增加时，Review 可以直接检查映射是否同步更新。
    -->
    <resultMap id="UserEntityResultMap" type="com.eventhub.modules.auth.entity.UserEntity">
        <id property="id" column="id" javaType="java.lang.Long"/>
        <result property="username" column="username" javaType="java.lang.String"/>
        <result property="email" column="email" javaType="java.lang.String"/>
        <result property="passwordHash" column="password_hash" javaType="java.lang.String"/>
        <result property="status" column="status" javaType="com.eventhub.modules.auth.enums.UserStatus"/>
        <result property="createdAt" column="created_at" javaType="java.time.LocalDateTime"/>
        <result property="updatedAt" column="updated_at" javaType="java.time.LocalDateTime"/>
    </resultMap>

    <sql id="UserColumns">
        id, username, email, password_hash, status, created_at, updated_at
    </sql>

    <select id="existsByUsername" resultType="boolean">
        SELECT CASE WHEN COUNT(*) > 0 THEN TRUE ELSE FALSE END
        FROM users
        WHERE username = #{username}
    </select>

    <select id="existsByEmail" resultType="boolean">
        SELECT CASE WHEN COUNT(*) > 0 THEN TRUE ELSE FALSE END
        FROM users
        WHERE email = #{email}
    </select>

    <!--
        useGeneratedKeys 会读取数据库生成的自增主键，并回填到 UserEntity.id。
        keyColumn 显式限定回填列为 id，避免不同数据库驱动返回额外 generated keys 时产生歧义。
    -->
    <insert id="insert"
            parameterType="com.eventhub.modules.auth.entity.UserEntity"
            useGeneratedKeys="true"
            keyProperty="id"
            keyColumn="id">
        INSERT INTO users (username, email, password_hash, status)
        VALUES (#{username}, #{email}, #{passwordHash}, #{status})
    </insert>

    <select id="findByUsernameOrEmail" resultMap="UserEntityResultMap">
        SELECT
        <include refid="UserColumns"/>
        FROM users
        WHERE username = #{usernameOrEmail}
           OR email = #{usernameOrEmail}
        LIMIT 1
    </select>

    <select id="findById" resultMap="UserEntityResultMap">
        SELECT
        <include refid="UserColumns"/>
        FROM users
        WHERE id = #{userId}
    </select>

    <select id="findAll" resultMap="UserEntityResultMap">
        SELECT
        <include refid="UserColumns"/>
        FROM users
        ORDER BY id ASC
    </select>

    <update id="updateStatus">
        UPDATE users
        SET status = #{status},
            updated_at = CURRENT_TIMESTAMP
        WHERE id = #{userId}
    </update>
</mapper>
